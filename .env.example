# ---------------------------------------------------------------------------
# Team Scheduler configuration
#
# Copy this file to ".env.local" and fill in values to enable CLOUD mode
# (accounts + co-parent sharing + realtime sync + reliable reminders).
#
# Leave these blank/absent to run in LOCAL mode (single device, no backend) —
# perfect for trying the app immediately.
# ---------------------------------------------------------------------------

# From Supabase: Project Settings → API
VITE_SUPABASE_URL=https://dvrgfcixmxszxpyjthgm.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_5kAiUQFq2kT5E5jxIZ

# Public VAPID key for Web Push (generate with: npx web-push generate-vapid-keys)
# The matching PRIVATE key is stored as a Supabase secret, never here.
VITE_VAPID_PUBLIC_KEY=
